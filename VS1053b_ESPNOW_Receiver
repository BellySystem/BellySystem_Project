#include <Arduino.h>
#include <SPI.h>
#include <SD.h>
#include <VS1053.h>
#include <esp_now.h>
#include <WiFi.h>

// ── Pines ──────────────────────────────────────────────────────────────
#define VS1053_CS     5
#define VS1053_DCS    22
#define VS1053_DREQ   4
#define VS1053_RESET  21
#define SD_CS         15

// ── Configuración MIDI ─────────────────────────────────────────────────
#define MIDI_CH       0
#define MIDI_PROGRAM  40
#define NOTE_VELOCITY 100

// ── Constructor: 3 argumentos ───────────────────────────────
VS1053 player(VS1053_CS, VS1053_DCS, VS1053_DREQ);

// ── Cola de mensajes ───────────────────────────────────────────────────
#define QUEUE_SIZE 10
QueueHandle_t messageQueue;

typedef struct {
  char command[20];
} ESPNowMessage;

bool midiModeActive = false;

// ── Prototipos ─────────────────────────────────────────────────────────
void playFile(const char* filename);
void stopPlayback();
void activateMidiMode();
void sendMidiByte(uint8_t data);
void sendMidiNoteOn(uint8_t channel, uint8_t note, uint8_t velocity);
void sendMidiNoteOff(uint8_t channel, uint8_t note);
void sendMidiProgramChange(uint8_t channel, uint8_t program);
void processCommand(const char* command);

// ── Callback ESP-NOW corregido: nueva firma IDF v5 ────────────────────
void onDataReceived(const esp_now_recv_info* info,
                    const uint8_t* data,
                    int len) {
  ESPNowMessage msg;
  memset(msg.command, 0, sizeof(msg.command));
  memcpy(msg.command, data, min(len, (int)sizeof(msg.command) - 1));
  xQueueSendFromISR(messageQueue, &msg, NULL);
}

// ──────────────────────────────────────────────────────────────────────
void setup() {
  Serial.begin(115200);
  Serial.println("\n=== VS1053b Receptor ESP-NOW ===");
  
  messageQueue = xQueueCreate(QUEUE_SIZE, sizeof(ESPNowMessage));

  // Reset manual del VS1053 ──────────────────────────────────────────
  pinMode(VS1053_RESET, OUTPUT);
  digitalWrite(VS1053_RESET, LOW);
  delay(20);
  digitalWrite(VS1053_RESET, HIGH);
  delay(20);

  // ESP-NOW ─────────────────────────────────────────────────────────
  WiFi.mode(WIFI_STA);
  WiFi.disconnect();

  if (esp_now_init() != ESP_OK) {
    Serial.println("ERROR: ESP-NOW no pudo inicializarse.");
    while (true) delay(1000);
  }
  esp_now_register_recv_cb(onDataReceived);
  Serial.println("ESP-NOW OK");
  Serial.print("MAC: ");
  Serial.println(WiFi.macAddress());

  // VS1053 ──────────────────────────────────────────────────────────
  SPI.begin();
  player.begin();

  if (!player.isChipConnected()) {
    Serial.println("ERROR: VS1053b no detectado.");
    while (true) delay(1000);
  }

  // setVolume: un solo argumento, rango 0-21
  player.setVolume(5);
  Serial.println("VS1053b OK");

  // SD ──────────────────────────────────────────────────────────────
  if (!SD.begin(SD_CS)) {
    Serial.println("ERROR: SD card no encontrada.");
    while (true) delay(1000);
  }
  Serial.println("SD card OK");

  if (!SD.exists("/dum.wav"))
    Serial.println("ADVERTENCIA: dum.wav no encontrado");
  if (!SD.exists("/tek.wav"))
    Serial.println("ADVERTENCIA: tek.wav no encontrado");

  Serial.println("Sistema listo, esperando comandos...");
}

// ──────────────────────────────────────────────────────────────────────
void loop() {
  ESPNowMessage msg;
  if (xQueueReceive(messageQueue, &msg, 0) == pdTRUE) {
    processCommand(msg.command);
  }
}

// ──────────────────────────────────────────────────────────────────────
void processCommand(const char* command) {
  Serial.printf("Comando recibido: %s\n", command);

  if (strcmp(command, "DUM") == 0) {
    stopPlayback();
    playFile("/dum.wav");
  }
  else if (strcmp(command, "TEK") == 0) {
    stopPlayback();
    playFile("/tek.wav");
  }
  else if (strncmp(command, "NOTE_ON_", 8) == 0) {
    uint8_t note = atoi(command + 8);
    if (!midiModeActive) {
      stopPlayback();
      activateMidiMode();
    }
    sendMidiNoteOn(MIDI_CH, note, NOTE_VELOCITY);
  }
  else if (strncmp(command, "NOTE_OFF_", 9) == 0) {
    uint8_t note = atoi(command + 9);
    sendMidiNoteOff(MIDI_CH, note);
  }
  else {
    Serial.printf("Comando desconocido: %s\n", command);
  }
}

// ──────────────────────────────────────────────────────────────────────
void playFile(const char* filename) {
  midiModeActive = false;

  File audioFile = SD.open(filename);
  if (!audioFile) {
    Serial.printf("ERROR: No se pudo abrir %s\n", filename);
    return;
  }
  Serial.printf("Reproduciendo: %s (%lu bytes)\n",
                filename, (unsigned long)audioFile.size());

  uint8_t buffer[32];

  while (audioFile.available()) {
    while (!player.data_request()) delayMicroseconds(10);

    uint32_t bytesLeidos = audioFile.read(buffer, sizeof(buffer));
    if (bytesLeidos > 0) {
      player.playChunk(buffer, bytesLeidos);
    }

    // Interrupción si llega nuevo comando
    ESPNowMessage msg;
    if (xQueueReceive(messageQueue, &msg, 0) == pdTRUE) {
      Serial.println("Nuevo comando, interrumpiendo reproducción.");
      audioFile.close();
      player.softReset();
      processCommand(msg.command);
      return;
    }
  }

  audioFile.close();

  // Fin limpio según datasheet sección 10.5.1
  // endFillByte es privado en esta librería → usar 0
  uint8_t fillBuffer[32];
  memset(fillBuffer, 0, sizeof(fillBuffer));
  for (int i = 0; i < 65; i++) {
    while (!player.data_request()) delayMicroseconds(10);
    player.playChunk(fillBuffer, sizeof(fillBuffer));
  }

  player.softReset();
  Serial.println("Reproducción finalizada.");
}

// ──────────────────────────────────────────────────────────────────────
void stopPlayback() {
  player.softReset();
  midiModeActive = false;
  delay(20);
}

void activateMidiMode() {
  player.setVolume(21);   // 1 argumento
  sendMidiProgramChange(MIDI_CH, MIDI_PROGRAM);
  midiModeActive = true;
  Serial.println("Modo MIDI activado (Violin GM1)");
}

void sendMidiByte(uint8_t data) {
  while (!player.data_request()) delayMicroseconds(10);
  uint8_t buffer[2] = {0x00, data};
  player.playChunk(buffer, 2);
}

void sendMidiNoteOn(uint8_t channel, uint8_t note, uint8_t velocity) {
  sendMidiByte(0x90 | (channel & 0x0F));
  sendMidiByte(note & 0x7F);
  sendMidiByte(velocity & 0x7F);
}

void sendMidiNoteOff(uint8_t channel, uint8_t note) {
  sendMidiByte(0x80 | (channel & 0x0F));
  sendMidiByte(note & 0x7F);
  sendMidiByte(0x00);
}

void sendMidiProgramChange(uint8_t channel, uint8_t program) {
  sendMidiByte(0xC0 | (channel & 0x0F));
  sendMidiByte(program & 0x7F);
}
